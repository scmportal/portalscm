# Copie este arquivo para `.env` e preencha com seus valores.
# Nunca comite o arquivo `.env`.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ── Vistoria · SharePoint via Microsoft Graph (MSAL) — opcional ───
# Sem estas variáveis a aba "Vistoria Mensal" roda em modo simulado.
VITE_MSAL_TENANT_ID=
VITE_MSAL_CLIENT_ID=
VITE_SP_SITE_ID=
VITE_SP_LIST_ID=
VITE_SP_CAMPO_CNPJ=CNPJ
